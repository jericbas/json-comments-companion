{
  "name": "json-comments-companion",
  "displayName": "JSON Comments Companion",
  "description": "Pair JSON files with companion comment files for hover and CodeLens documentation",
  "version": "0.2.0",
  "publisher": "jericbas",
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Other",
    "Visualization"
  ],
  "keywords": [
    "json",
    "comments",
    "documentation",
    "hover",
    "codelens"
  ],
  "activationEvents": [
    "onLanguage:json"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "jsonCommentsCompanion.openCommentsFile",
        "title": "JSON: Open Comments File"
      },
      {
        "command": "jsonCommentsCompanion.toggleHover",
        "title": "JSON: Toggle Hover Comments"
      },
      {
        "command": "jsonCommentsCompanion.toggleCodeLens",
        "title": "JSON: Toggle CodeLens Comments"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "jsonCommentsCompanion.openCommentsFile",
          "when": "true"
        },
        {
          "command": "jsonCommentsCompanion.toggleHover",
          "when": "true"
        },
        {
          "command": "jsonCommentsCompanion.toggleCodeLens",
          "when": "true"
        }
      ],
      "editor/context": [
        {
          "command": "jsonCommentsCompanion.openCommentsFile",
          "group": "2_configuration@5",
          "when": "editorLangId == json"
        }
      ]
    },
    "configuration": {
      "title": "JSON Comments Companion",
      "properties": {
        "jsonCommentsCompanion.hoverEnabled": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Show comments on hover over JSON keys"
        },
        "jsonCommentsCompanion.codeLensEnabled": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Show CodeLens annotations above JSON keys with comments"
        },
        "jsonCommentsCompanion.filePattern": {
          "type": "string",
          "default": "{filename}.comments.json",
          "markdownDescription": "Pattern for comment files. Use `{filename}` as placeholder for the base name."
        },
        "jsonCommentsCompanion.maxCommentLength": {
          "type": "number",
          "default": 50,
          "minimum": 10,
          "maximum": 200,
          "markdownDescription": "Maximum length of CodeLens comment text (excess truncated with ...)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js",
    "package": "vsce package --no-dependencies",
    "publish:marketplace": "vsce publish",
    "release": "npm run compile && npm run package",
    "release:patch": "npm version patch && npm run release && npm run publish:marketplace",
    "release:minor": "npm version minor && npm run release && npm run publish:marketplace",
    "release:major": "npm version major && npm run release && npm run publish:marketplace"
  },
  "devDependencies": {
    "@types/vscode": "^1.60.0",
    "@types/node": "16.x",
    "@typescript-eslint/eslint-plugin": "^5.1.0",
    "@typescript-eslint/parser": "^5.1.0",
    "eslint": "^8.1.0",
    "typescript": "^4.4.4",
    "@vscode/vsce": "^2.15.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jericbas/json-comments-companion.git"
  },
  "bugs": {
    "url": "https://github.com/jericbas/json-comments-companion/issues"
  },
  "homepage": "https://github.com/jericbas/json-comments-companion#readme",
  "icon": "images/icon.png"
}
