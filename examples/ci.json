{
  "name": "CI Pipeline",
  "on": ["push", "pull_request"],
  "jobs": {
    "test": {
      "runs-on": "ubuntu-latest",
      "steps": [
        { "uses": "actions/checkout@v4" },
        { "uses": "actions/setup-node@v4", "with": { "node-version": "18" } }
      ]
    },
    "deploy": {
      "needs": ["test"],
      "if": "github.ref == 'refs/heads/main'",
      "runs-on": "ubuntu-latest"
    }
  }
}
