{
  "name": "json-comments-example",
  "displayName": "JSON Comments Example",
  "description": "An example VS Code extension",
  "version": "1.0.0",
  "publisher": "jericbas",
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": ["Other"],
  "activationEvents": ["onCommand:example.hello"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "example.hello",
        "title": "Hello World"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.60.0",
    "typescript": "^4.4.4"
  }
}
